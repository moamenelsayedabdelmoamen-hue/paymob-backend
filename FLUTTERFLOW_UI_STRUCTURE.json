{
  "appName": "البطل أكسبريس",
  "language": "ar",
  "direction": "rtl",
  "theme": {
    "primaryColor": "#0E6B3B",
    "secondaryColor": "#FFFFFF",
    "accentColor": "#1FAE5B",
    "textColor": "#1F2937",
    "mutedTextColor": "#6B7280",
    "backgroundColor": "#F8FAF8",
    "fontFamily": "Tajawal",
    "borderRadius": 16,
    "elevation": 2
  },
  "navigation": {
    "initialRoute": "/splash",
    "routes": [
      "/splash",
      "/login",
      "/restaurant/home",
      "/restaurant/create-order",
      "/restaurant/orders",
      "/restaurant/order-details",
      "/captain/login",
      "/captain/home",
      "/captain/nearby-orders",
      "/captain/order-details",
      "/captain/map"
    ]
  },
  "pages": [
    {
      "id": "splash",
      "title": "شاشة البداية",
      "type": "welcome",
      "layout": "centered",
      "components": [
        {
          "type": "image",
          "name": "logo",
          "asset": "assets/logo.png",
          "width": 180,
          "height": 180
        },
        {
          "type": "text",
          "name": "appTitle",
          "text": "البطل أكسبريس",
          "fontSize": 30,
          "fontWeight": "bold",
          "color": "#0E6B3B"
        },
        {
          "type": "text",
          "name": "appSubtitle",
          "text": "نظام لوجستي سهل وسريع",
          "fontSize": 16,
          "color": "#6B7280"
        },
        {
          "type": "button",
          "name": "startButton",
          "text": "ابدأ الآن",
          "onTap": "navigate:/login"
        }
      ]
    },
    {
      "id": "login",
      "title": "اختيار نوع الحساب",
      "type": "authChoice",
      "layout": "column",
      "components": [
        {
          "type": "text",
          "text": "اختر نوع الحساب",
          "fontSize": 24,
          "fontWeight": "bold"
        },
        {
          "type": "cardButton",
          "title": "تطبيق المطاعم",
          "subtitle": "إنشاء الطلبات ومتابعتها",
          "onTap": "navigate:/restaurant/home"
        },
        {
          "type": "cardButton",
          "title": "تطبيق الكابتن",
          "subtitle": "قبول الطلبات والتوصيل",
          "onTap": "navigate:/captain/home"
        }
      ]
    },
    {
      "id": "restaurantHome",
      "title": "الرئيسية - المطعم",
      "type": "dashboard",
      "layout": "column",
      "components": [
        {
          "type": "appBar",
          "title": "لوحة المطعم",
          "actions": [
            { "type": "iconButton", "icon": "logout", "onTap": "navigate:/login" }
          ]
        },
        {
          "type": "summaryCard",
          "title": "الطلبات النشطة",
          "value": "12",
          "subtitle": "طلبًا جاريًا"
        },
        {
          "type": "summaryCard",
          "title": "الطلبات المكتملة",
          "value": "48",
          "subtitle": "طلبًا خلال اليوم"
        },
        {
          "type": "button",
          "text": "إنشاء طلب جديد",
          "onTap": "navigate:/restaurant/create-order"
        },
        {
          "type": "button",
          "text": "عرض جميع الطلبات",
          "onTap": "navigate:/restaurant/orders"
        }
      ]
    },
    {
      "id": "restaurantCreateOrder",
      "title": "إنشاء طلب جديد",
      "type": "form",
      "layout": "scroll",
      "components": [
        {
          "type": "appBar",
          "title": "طلب جديد"
        },
        {
          "type": "textField",
          "label": "اسم العميل",
          "name": "customerName",
          "required": true
        },
        {
          "type": "textField",
          "label": "رقم الهاتف",
          "name": "customerPhone",
          "keyboardType": "phone",
          "required": true
        },
        {
          "type": "textField",
          "label": "عنوان التوصيل",
          "name": "deliveryAddress",
          "required": true
        },
        {
          "type": "mapPicker",
          "label": "اختيار الموقع على الخريطة",
          "name": "deliveryLocation"
        },
        {
          "type": "textField",
          "label": "المبلغ",
          "name": "totalAmount",
          "keyboardType": "number"
        },
        {
          "type": "textField",
          "label": "رسوم التوصيل",
          "name": "deliveryFee",
          "keyboardType": "number"
        },
        {
          "type": "textField",
          "label": "الملاحظات",
          "name": "notes",
          "multiline": true
        },
        {
          "type": "button",
          "text": "إرسال الطلب",
          "onTap": "submitOrder"
        }
      ]
    },
    {
      "id": "restaurantOrders",
      "title": "قائمة الطلبات",
      "type": "list",
      "layout": "column",
      "components": [
        {
          "type": "appBar",
          "title": "الطلبات"
        },
        {
          "type": "listView",
          "dataSource": "ordersByRestaurant",
          "itemTemplate": {
            "title": "{{customer_name}}",
            "subtitle": "{{status}} · {{delivery_address}}",
            "trailingText": "{{total_amount}} جنيه",
            "onTap": "navigate:/restaurant/order-details?id={{id}}"
          }
        }
      ]
    },
    {
      "id": "restaurantOrderDetails",
      "title": "تفاصيل الطلب",
      "type": "details",
      "layout": "scroll",
      "components": [
        {
          "type": "appBar",
          "title": "تفاصيل الطلب"
        },
        {
          "type": "statusBadge",
          "label": "{{status}}"
        },
        {
          "type": "detailRow",
          "label": "اسم العميل",
          "value": "{{customer_name}}"
        },
        {
          "type": "detailRow",
          "label": "رقم الهاتف",
          "value": "{{customer_phone}}"
        },
        {
          "type": "detailRow",
          "label": "العنوان",
          "value": "{{delivery_address}}"
        },
        {
          "type": "detailRow",
          "label": "المبلغ",
          "value": "{{total_amount}} جنيه"
        },
        {
          "type": "detailRow",
          "label": "الكابتن",
          "value": "{{captain_name}}"
        },
        {
          "type": "mapView",
          "lat": "{{delivery_lat}}",
          "lng": "{{delivery_lng}}"
        }
      ]
    },
    {
      "id": "captainLogin",
      "title": "تسجيل دخول الكابتن",
      "type": "auth",
      "layout": "column",
      "components": [
        {
          "type": "text",
          "text": "تسجيل الدخول",
          "fontSize": 24,
          "fontWeight": "bold"
        },
        {
          "type": "textField",
          "label": "رقم الهاتف",
          "name": "phone",
          "keyboardType": "phone"
        },
        {
          "type": "button",
          "text": "دخول",
          "onTap": "navigate:/captain/home"
        }
      ]
    },
    {
      "id": "captainHome",
      "title": "الرئيسية - الكابتن",
      "type": "dashboard",
      "layout": "column",
      "components": [
        {
          "type": "appBar",
          "title": "لوحة الكابتن"
        },
        {
          "type": "statusSwitch",
          "label": "الحالة",
          "values": ["متاح", "مشغول", "غير متاح"],
          "defaultValue": "متاح"
        },
        {
          "type": "button",
          "text": "الطلبات القريبة",
          "onTap": "navigate:/captain/nearby-orders"
        },
        {
          "type": "button",
          "text": "عرض الخريطة",
          "onTap": "navigate:/captain/map"
        }
      ]
    },
    {
      "id": "captainNearbyOrders",
      "title": "الطلبات القريبة",
      "type": "list",
      "layout": "column",
      "components": [
        {
          "type": "appBar",
          "title": "الطلبات القريبة"
        },
        {
          "type": "listView",
          "dataSource": "pendingOrdersNearby",
          "itemTemplate": {
            "title": "{{restaurant_name}}",
            "subtitle": "{{delivery_address}} · {{distance_km}} كم",
            "trailingText": "{{total_amount}} جنيه",
            "onTap": "navigate:/captain/order-details?id={{id}}"
          }
        }
      ]
    },
    {
      "id": "captainOrderDetails",
      "title": "تفاصيل الطلب للكابتن",
      "type": "details",
      "layout": "scroll",
      "components": [
        {
          "type": "appBar",
          "title": "تفاصيل الطلب"
        },
        {
          "type": "detailRow",
          "label": "اسم المطعم",
          "value": "{{restaurant_name}}"
        },
        {
          "type": "detailRow",
          "label": "العنوان",
          "value": "{{delivery_address}}"
        },
        {
          "type": "detailRow",
          "label": "المبلغ",
          "value": "{{total_amount}} جنيه"
        },
        {
          "type": "detailRow",
          "label": "الملاحظات",
          "value": "{{notes}}"
        },
        {
          "type": "button",
          "text": "قبول الطلب",
          "variant": "primary",
          "onTap": "acceptOrder"
        },
        {
          "type": "button",
          "text": "تم التسليم",
          "variant": "secondary",
          "onTap": "markDelivered"
        },
        {
          "type": "mapView",
          "lat": "{{delivery_lat}}",
          "lng": "{{delivery_lng}}"
        }
      ]
    },
    {
      "id": "captainMap",
      "title": "الخريطة",
      "type": "map",
      "layout": "fullScreen",
      "components": [
        {
          "type": "googleMap",
          "initialLocation": "currentLocation",
          "markers": ["activeOrders"]
        }
      ]
    }
  ],
  "state": {
    "auth": {
      "userRole": "restaurant|captain"
    },
    "orders": {
      "selectedOrderId": ""
    },
    "captain": {
      "status": "available"
    }
  },
  "actions": [
    {
      "name": "submitOrder",
      "type": "apiCall",
      "endpoint": "POST /api/orders"
    },
    {
      "name": "acceptOrder",
      "type": "apiCall",
      "endpoint": "POST /api/orders/:id/accept"
    },
    {
      "name": "markDelivered",
      "type": "apiCall",
      "endpoint": "POST /api/orders/:id/deliver"
    },
    {
      "name": "loadPendingOrders",
      "type": "apiCall",
      "endpoint": "GET /api/orders/pending"
    }
  ]
}
